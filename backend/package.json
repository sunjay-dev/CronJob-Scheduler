{
  "name": "backend",
  "version": "1.0.0",
  "description": "backend for cronJob Scheduler",
  "main": "dist/src/app.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env ./dist/src/server.js",
    "watch": "tsc -w",
    "build": "tsc -p tsconfig.build.json",
    "dev": "concurrently \"tsc -w\" \"node --watch ./dist/src/server.js\"",
    "bun": "bun ./src/server.ts",
    "bun watch": "bun --watch ./src/server.ts",
    "test": "vitest run"
  },
  "author": "https://github.com/sunjay-dev/",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "agenda": "^5.0.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cron-validator": "^1.3.1",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.8.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.3.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^9.10.0",
    "prom-client": "^15.1.3",
    "validator": "^13.15.15",
    "zod": "^4.0.15"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.5.2",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.2",
    "concurrently": "^9.2.0",
    "dotenv": "^17.0.1",
    "mockingoose": "^3.0.0",
    "pino-pretty": "^13.1.1",
    "supertest": "^7.2.2",
    "typescript": "^5.9.2",
    "vitest": "^4.1.0"
  }
}
